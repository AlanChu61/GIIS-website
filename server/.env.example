# =============================================================================
# GIIS Transcript API — copy this file to server/.env and adjust per environment
# =============================================================================
#
# Prisma uses PostgreSQL only (see prisma/schema.prisma). Same stack locally and on AWS.
#
# ── Local development (recommended) ─────────────────────────────────────────
# 1. From REPO ROOT:  docker compose up -d
# 2. Copy this file to server/.env
# 3. In server/:  npx prisma db push && npm run db:seed && npm run dev
#
DATABASE_URL="postgresql://giis:giis_dev@localhost:5432/giis_transcript?schema=public"
#
# ── AWS Lightsail / production ─────────────────────────────────────────────
# Use your managed PostgreSQL URL (Lightsail Database) or self-hosted Postgres.
# Many AWS endpoints REQUIRE TLS — append ssl parameters, for example:
#
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"
#
# If the provider uses a self-signed cert during testing only (not recommended prod):
# ?schema=public&sslmode=require&sslaccept=accept_invalid_certs
#
# JWT_SECRET: long random string, unique per environment (never commit real values).
# CORS_ORIGIN: your public site origin(s), comma-separated, no trailing slash:
#   https://genesisideas.school
# TRUST_PROXY: set to 1 if the API sits behind Lightsail LB / nginx with HTTPS.
#
# DATABASE_URL="postgresql://..."
# JWT_SECRET="(32+ random bytes, openssl rand -hex 32)"
# PORT=4000
# CORS_ORIGIN="https://your-frontend-domain"
# TRUST_PROXY=1
#
# ── Shared variables ───────────────────────────────────────────────────────

JWT_SECRET="change-this-to-a-long-random-string-in-production"
PORT=4000
# Frontend dev server; in production list only real site URL(s)
CORS_ORIGIN="http://localhost:3000"
# Seed script only — change after first login in production
ADMIN_EMAIL="admin@genesisideas.school"
ADMIN_SEED_PASSWORD="admin"
